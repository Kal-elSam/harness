{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "steps": 8
    },
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "git diff *": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "npm run test*": "allow",
          "pnpm run test*": "allow"
        }
      },
      "steps": 12
    }
  }
}
